```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
.gradle/

# Python specific
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/
.coverage
coverage/
htmlcov/

# JavaScript/Node
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/
*.swp
*.swo

# System
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```